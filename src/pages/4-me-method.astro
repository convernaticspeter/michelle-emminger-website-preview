---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQ from '../components/FAQ.astro';
import Inquiry from '../components/Inquiry.astro';
import Icon from '../components/Icon.astro';

const faq = [
  { q: 'Was ist die 4-ME Method?', a: 'Die 4-ME Method ist Michelle Emmingers Trainingsansatz. Sie verbindet My Body, My Mind, My Life und My Success, damit Training nicht nur als Übungsplan funktioniert, sondern als System für Körper, Kopf, Alltag und messbaren Fortschritt.' },
  { q: 'Warum braucht Training mehr als Übungen?', a: 'Übungen allein lösen selten das eigentliche Problem. Wer langfristig stärker werden will, braucht Technik, Motivation, Routinen, realistische Ziele und einen Umgang mit Rückschlägen. Genau diese Bereiche verbindet die 4-ME Method.' },
  { q: 'Für wen ist die Methode geeignet?', a: 'Die Methode eignet sich für Menschen, die Veränderung ernst meinen, aber keinen extremen Fitness-Lifestyle suchen. Besonders passend ist sie für Erwachsene 40+, Wiedereinsteiger, Menschen mit wenig Zeit und alle, die mehr Struktur und Sicherheit brauchen.' },
  { q: 'Wird die Methode auch in der Firmenfitness genutzt?', a: 'Ja. Für Teams wird die Methode auf den Arbeitsalltag übersetzt: Körper entlasten, Kopf freier bekommen, Bewegung in Routinen einbauen und kleine Erfolge sichtbar machen.' }
];

const pillars = [
  {
    icon: 'body',
    label: '01',
    title: 'My Body',
    copy: 'Gute Technik, Kraft, Mobilität, Haltung und Körpergefühl. Der Körper wird verstanden, kontrolliert bewegt und gezielt aufgebaut.'
  },
  {
    icon: 'mind',
    label: '02',
    title: 'My Mind',
    copy: 'Sicherheit, Vertrauen und Umgang mit Rückschlägen. Nicht jeder schlechte Tag ist ein Scheitern — oft braucht es nur einen besseren Umgang damit.'
  },
  {
    icon: 'life',
    label: '03',
    title: 'My Life',
    copy: 'Training, Ernährung und Routinen müssen in deinen Alltag passen. Sonst bleibt der beste Plan ein Dokument, das niemand lebt.'
  },
  {
    icon: 'success',
    label: '04',
    title: 'My Success',
    copy: 'Erfolg wird sichtbar gemacht: mehr Kraft, bessere Haltung, mehr Energie, mehr Vertrauen — nicht nur eine Zahl auf der Waage.'
  }
];

const applications = [
  {
    icon: 'personal',
    title: 'Im Personal Training',
    copy: 'Technik, Kraft, Haltung und Routine werden persönlich aufgebaut. Michelle sieht, wie du dich bewegst, korrigiert direkt und passt den Plan an deinen Fortschritt an.',
    href: '/personal-training-wien/',
    cta: 'Zum Personal Training'
  },
  {
    icon: 'online',
    title: 'Im Online Coaching',
    copy: 'Du bekommst einen Plan, Rückmeldung und Orientierung, ohne an einen Ort gebunden zu sein. Der Fokus liegt auf Dranbleiben, Umsetzen und Nachschärfen.',
    href: '/online-coaching/',
    cta: 'Zum Online Coaching'
  },
  {
    icon: 'office',
    title: 'In der Firmenfitness',
    copy: 'Für Teams wird die Methode niedrigschwellig: kurze Einheiten, reale Bürobelastung, kleine Routinen und Akzeptanz statt Pflichtprogramm.',
    href: '/firmenfitness/',
    cta: 'Zur Firmenfitness'
  }
];
---
<BaseLayout title="4-ME Method | Michelle Emminger Personal Training Wien" description="Die 4-ME Method von Michelle Emminger: die NUR für MICH Methode für Körper, Vertrauen, Alltag und Fortschritt." canonical="/4-me-method/" image="/assets/method.webp" faq={faq} serviceName="4-ME Method Personal Training">
  <section class="service-hero"><div class="container split"><div><p class="breadcrumbs"><a href="/">Start</a> / 4-ME Method</p><p class="eyebrow">My Body · My Mind · My Life · My Success</p><h1 class="page-title">Die 4-ME Method</h1><p class="lead">„4-ME METHOD“ – die NUR für MICH Methode: ein Trainingsansatz, der Körper, Alltag, mentale Stärke und Fortschritt zusammenbringt – damit Training zu dir passt und nicht nur gut klingt.</p><div class="hero-actions"><a class="btn primary" href="#anfrage">Einschätzung anfragen</a><a class="btn light" href="/personal-training-wien/">Personal Training ansehen</a></div></div><div class="image-card"><img src="/assets/method.webp" alt="Michelle Emminger 4-ME Method Personal Training" loading="eager" fetchpriority="high"/></div></div></section>
  <section class="section"><div class="container narrow"><p class="eyebrow">Definition</p><h2>Was bedeutet die 4-ME Method?</h2><p class="answer-block">Die 4-ME Method ist Michelle Emmingers „NUR für MICH Methode“: ein persönlicher Aufbau für Menschen, die nicht nur einzelne Übungen brauchen, sondern einen Weg, der zu Körper, Kopf, Woche und Ziel passt.</p><p>Die Methode ist aus Michelles eigener Geschichte entstanden. Sie kennt Rückschläge, Unsicherheit und den langen Weg zurück zu mehr Kraft aus eigener Erfahrung. Wer das selbst erlebt hat, weiß: Ein Plan allein reicht selten. Entscheidend ist, ob ein Mensch den nächsten Schritt wirklich gehen kann — und ob das System dahinter stabil genug ist, um dranzubleiben. Genau das wollte sie mit der 4-ME Method schaffen.</p></div></section>
  <section class="section alt"><div class="container"><p class="eyebrow">Die vier Säulen</p><h2>Die vier Bereiche greifen ineinander.</h2><div class="grid four graphic-grid">{pillars.map((pillar) => (<div class="card graphic-card pillar-card"><div class="card-topline"><span class="icon-badge"><Icon name={pillar.icon} /></span><span class="card-index">{pillar.label}</span></div><h3>{pillar.title}</h3><p>{pillar.copy}</p></div>))}</div></div></section>
  <section class="section"><div class="container split"><div><p class="eyebrow">Warum diese Methode anders ist</p><h2>Die Methode setzt dort an, wo viele Trainingspläne scheitern: im Alltag.</h2><p>Viele Menschen wissen, was „gesund” wäre. Trotzdem scheitert es an Zeit, Unsicherheit, Erschöpfung, alten Mustern oder dem Gefühl, nicht dazuzugehören. Das passiert besonders oft ab 40, wenn Alltag, Beruf und Körper gleichzeitig anspruchsvoller werden. Die 4-ME Method macht diese Faktoren sichtbar, statt sie zu ignorieren.</p><p>Dadurch wird Training persönlicher. Ein Mensch mit Rückenangst braucht einen anderen Einstieg als jemand, der Muskelaufbau will. Ein Team im Büro braucht ein anderes Format als eine Person im 1:1. Die Methode sorgt dafür, dass der Rahmen gleich bleibt, aber die Umsetzung individuell wird.</p></div><div class="card dark graphic-card dark-graphic"><span class="icon-badge dark-icon"><Icon name="route" /></span><h3>Kein Motivationsspruch. Ein Arbeitsrahmen.</h3><p>From Struggle to Strength bedeutet nicht, immer stark zu tun. Es bedeutet, ehrlich zu starten und Schritt für Schritt einen Rahmen aufzubauen, der trägt. Dafür braucht es keinen Standardplan, sondern einen Einstieg, der zu Körper, Alltag und Ziel passt.</p></div></div></section>
  <section class="section alt"><div class="container"><p class="eyebrow">Anwendung</p><h2>So zeigt sich die 4-ME Method in Michelles Angeboten.</h2><div class="grid three graphic-grid">{applications.map((item) => (<div class="card graphic-card"><span class="icon-badge"><Icon name={item.icon} /></span><h3>{item.title}</h3><p>{item.copy}</p><a class="btn light" href={item.href}>{item.cta}</a></div>))}</div></div></section>
  <FAQ items={faq} heading="Häufige Fragen zur 4-ME Method" />
  <Inquiry format="Noch unsicher" />
</BaseLayout>
