---
import BaseLayout from '../layouts/BaseLayout.astro';

const mediaEmail = 'martina.zowack@zowack.com';
const mediaMailto = `mailto:${mediaEmail}?subject=Medienanfrage%20Michelle%20Emminger`;

const downloads = [
  {
    title: 'Pressekit',
    copy: 'DOCX-Informationen und hochqualitative JPEG-Pressebilder in einem ZIP-Paket.',
    href: '/media/michelle-emminger-pressekit.zip',
    meta: 'ZIP · Pressekit',
    featured: true
  },
  {
    title: 'Basispresseinformation',
    copy: 'Word-Datei für redaktionelle Weiterverarbeitung.',
    href: '/media/basispresseinformation-michelle-emminger-4-me-method.docx',
    meta: 'DOCX · Presseinfo'
  },
  {
    title: 'Hintergrundinfo: „From Struggle to Strength“ – eine Story, die Mut macht und motiviert',
    copy: 'Word-Datei für redaktionelle Weiterverarbeitung.',
    href: '/media/hintergrundinfo-michelle-emminger-from-struggle-to-strength.docx',
    meta: 'DOCX · Hintergrundinfo'
  }
];

const photos = [
  {
    src: '/media/media-michelle-portrait-card.webp',
    href: '/media/pressebild-michelle-emminger-portrait-copyright-frank-schmidhofer.jpg',
    alt: 'Michelle Emminger im Coaching-Gespräch',
    title: 'Michelle Emminger Portrait',
    width: 760,
    height: 507
  },
  {
    src: '/media/media-michelle-training-card.webp',
    href: '/media/pressebild-michelle-emminger-training-copyright-frank-schmidhofer.jpg',
    alt: 'Michelle Emminger begleitet eine Kundin beim Training',
    title: 'Michelle Emminger Training',
    width: 760,
    height: 507
  },
  {
    src: '/media/media-michelle-coaching-card.webp',
    href: '/media/pressebild-michelle-emminger-coaching-copyright-frank-schmidhofer.jpg',
    alt: 'Michelle Emminger korrigiert eine Übung',
    title: 'Michelle Emminger Coaching',
    width: 760,
    height: 507
  },
  {
    src: '/media/media-michelle-strength-card.webp',
    href: '/media/pressebild-michelle-emminger-krafttraining-copyright-frank-schmidhofer.jpg',
    alt: 'Michelle Emminger zeigt Krafttraining',
    title: 'Michelle Emminger Krafttraining',
    width: 760,
    height: 507
  },
  {
    src: '/media/media-michelle-hanteltraining-card.webp',
    href: '/media/pressebild-michelle-emminger-hanteltraining-copyright-frank-schmidhofer.jpg',
    alt: 'Michelle Emminger beim Hanteltraining vor dem Spiegel',
    title: 'Michelle Emminger Hanteltraining',
    width: 760,
    height: 507
  },
  {
    src: '/media/media-michelle-medizinballtraining-card.webp',
    href: '/media/pressebild-michelle-emminger-medizinballtraining-copyright-frank-schmidhofer.jpg',
    alt: 'Michelle Emminger begleitet eine Kundin beim Medizinballtraining',
    title: 'Michelle Emminger Medizinballtraining',
    width: 760,
    height: 507
  },
  {
    src: '/assets/hero-training.webp',
    href: '/media/pressebild-michelle-emminger-personal-training-copyright-frank-schmidhofer.jpg',
    alt: 'Michelle Emminger beim Training',
    title: 'Michelle Emminger Personal Training',
    width: 1200,
    height: 900
  },
  {
    src: '/assets/personal-training.webp',
    href: '/media/pressebild-michelle-emminger-1zu1-training-copyright-frank-schmidhofer.jpg',
    alt: 'Michelle Emminger im Personal Training',
    title: 'Michelle Emminger 1:1 Training',
    width: 1200,
    height: 900
  }
];

const site = Astro.site || 'https://michelle.preview.convernatics.eu';
const mediaBase = new URL('/media-center/', site).toString();
const imageObjects = photos.map((photo) => ({
  '@type': 'ImageObject',
  name: photo.title,
  contentUrl: new URL(photo.href, site).toString(),
  thumbnailUrl: new URL(photo.src, site).toString(),
  caption: photo.title,
  creditText: 'Frank Schmidhofer',
  copyrightNotice: 'Copyright: Frank Schmidhofer',
  creator: { '@type': 'Person', name: 'Frank Schmidhofer' },
  acquireLicensePage: mediaBase
}));
const extraSchema = [
  ...imageObjects,
  {
    '@type': 'ContactPoint',
    '@id': `${mediaBase}#medienkontakt`,
    contactType: 'media relations',
    name: 'Dr. Martina Zowack',
    email: mediaEmail,
    telephone: '+43 676 3047112',
    availableLanguage: ['de', 'en']
  }
];
---
<BaseLayout
  title="Pressebilder Michelle Emminger | Presseinfo & Medienkontakt"
  description="Pressebereich von Michelle Emminger: Presse- und Hintergrundinformation, Pressebilder und Medienkontakt für Beiträge und Interviews."
  canonical="/media-center/"
  image="/media/media-michelle-portrait-hero.webp"
  pageType="CollectionPage"
  extraSchema={extraSchema}
  navCtaText="Medienanfrage senden"
  navCtaHref={mediaMailto}
  stickyCtaText="Medienanfrage senden"
  stickyCtaHref={mediaMailto}
  showStickyCta={false}
>
  <section class="service-hero media-hero">
    <div class="container split">
      <div>
        <p class="breadcrumbs"><a href="/">Start</a> / Media Center</p>
        <p class="eyebrow">Presseinformation · Pressebilder · Medienkontakt</p>
        <h1 class="page-title">Pressebereich Michelle Emminger</h1>
        <p class="lead">Presse- und Hintergrundinformation, Pressebilder, Kurzprofil und Medienkontakt für Beiträge und Interviews.</p>
        <div class="hero-actions">
          <a class="btn primary" href="#bildmaterial">Pressebilder ansehen</a>
          <a class="btn light" href="#downloads">Direktlinks öffnen</a>
        </div>
      </div>
      <div class="image-card"><img src="/media/media-michelle-portrait-hero.webp" alt="Michelle Emminger im Gespräch mit einer Kundin" width="1280" height="853" loading="eager" decoding="async" fetchpriority="high" /></div>
    </div>
  </section>

  <section id="downloads" class="section alt downloads-section">
    <div class="container">
      <p class="eyebrow">Downloads</p>
      <h2>Direktlinks für Redaktionen.</h2>
      <p class="download-intro">Basispresseinformation und Hintergrundinfo stehen als DOCX-Dateien bereit.</p>
      <div class="download-grid">
        {downloads.map((item) => (
          <a class:list={["download-card", item.featured && "featured"]} href={item.href} download>
            <span>{item.meta}</span>
            <h3>{item.title}</h3>
            <p>{item.copy}</p>
            <strong>Download</strong>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section id="bildmaterial" class="section media-gallery-section">
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow">Pressebilder</p>
          <h2>Pressebilder</h2>
        </div>
      </div>
      <div class="usage-note">
        <strong>Nutzungshinweis:</strong> Bilder für redaktionelle Berichterstattung frei verwendbar.
      </div>
      <div class="media-photo-grid">
        {photos.map((photo) => (
          <a class="media-photo" href={photo.href} download>
            <img src={photo.src} alt={photo.alt} width={photo.width} height={photo.height} loading="eager" decoding="async" />
            <div>
              <h3>{photo.title}</h3>
              <small>Copyright: Frank Schmidhofer</small>
              <span>JPEG herunterladen</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section id="medienkontakt" class="section">
    <div class="container split">
      <div>
        <p class="eyebrow">Medienkontakt</p>
        <h2>Ihr Kontakt für Medien-Anfragen</h2>
        <p>Für Interviews, redaktionelle Beiträge, Presseinformationen und Kooperationsanfragen steht gerne zur Verfügung:</p>
      </div>
      <div class="contact-card media-contact-card">
        <div class="media-contact-person">
          <img src="/media/dr-martina-zowack.webp" alt="Dr. Martina Zowack, Zowack PR & Communications" width="900" height="900" loading="lazy" decoding="async" />
          <div>
            <h3>Dr. Martina Zowack</h3>
            <p>Zowack PR & Communications</p>
          </div>
        </div>
        <p><a href="tel:+436763047112">+43 676 3047112</a><br /><a href={`mailto:${mediaEmail}`}>{mediaEmail}</a></p>
        <a class="btn primary" href={mediaMailto}>Medienanfrage senden</a>
      </div>
    </div>
  </section>

  <style>
    .media-gallery-section{background:#fff}
    .media-gallery-section .media-photo-grid{grid-template-columns:repeat(3,minmax(0,1fr))}
    .media-gallery-section .media-photo img{height:auto;object-fit:contain}
    .media-hero .image-card img{height:auto;min-height:0;aspect-ratio:auto;object-fit:contain}
    .downloads-section .download-intro{max-width:64ch;margin:-.4rem 0 1.2rem}
    .media-contact-card{display:grid;gap:1.05rem}
    .media-contact-person{display:grid;grid-template-columns:96px 1fr;gap:1rem;align-items:center}
    .media-contact-person img{width:96px;height:96px;border-radius:999px;object-fit:cover;box-shadow:0 14px 34px rgba(48,50,57,.16)}
    .media-contact-person h3{margin-bottom:.25rem}
    .media-contact-person p{margin:0}
    @media(max-width:960px){.media-gallery-section .media-photo-grid{grid-template-columns:1fr 1fr}}
    @media(max-width:640px){.media-gallery-section .media-photo-grid{grid-template-columns:1fr}.media-contact-person{grid-template-columns:76px 1fr}.media-contact-person img{width:76px;height:76px}}
  </style>
</BaseLayout>
