---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQ from '../components/FAQ.astro';

const mediaEmail = 'martina.zowack@zowack.com';
const mediaMailto = `mailto:${mediaEmail}?subject=Medienanfrage%20Michelle%20Emminger`;

const facts = [
  ['Name', 'Michelle Emminger'],
  ['Standort', 'Wien'],
  ['Tätigkeit', 'Personal-, Gesundheits- und Functional Trainerin, Personal Coach und Fitnessbetreuerin'],
  ['Erfahrung', 'über 1000 Stunden Coaching-Erfahrung'],
  ['Methode', '4-ME Method: My Body, My Mind, My Life, My Success'],
  ['Positionierung', 'From Struggle to Strength · Become your best ME'],
  ['Buch', 'Das einfachste Trainingsbuch der Welt']
];

const downloads = [
  {
    title: 'Komplettes Pressekit',
    copy: 'Alle PDFs, Logos, ausgewählte Pressebilder und Nutzungshinweise in einem ZIP-Paket.',
    href: '/media/michelle-emminger-pressekit.zip',
    meta: 'ZIP · Media Kit',
    featured: true
  },
  {
    title: 'Basis-Presseinfo',
    copy: 'Presseinformation zu Michelles 4-ME Method, ihrer persönlichen Transformation und ihrem modernen Coaching-Ansatz.',
    href: '/media/presseinformation-michelle-emminger-4-me-method.pdf',
    meta: 'PDF · Presseinfo 2026'
  },
  {
    title: 'Kurzprofil Michelle Emminger',
    copy: 'Ausführlicher Hintergrund zu Michelles Weg, From Struggle to Strength und ihrer Arbeit als Personal Coach und Fitness-Trainerin.',
    href: '/media/kurzprofil-michelle-emminger.pdf',
    meta: 'PDF · Profiltext'
  },
  {
    title: 'Logo-Paket',
    copy: 'Logo-Dateien in Farbe und Weiß. Nur bei Bedarf für Layout, Veranstaltergrafik oder Kooperationsmaterial.',
    href: '/media/michelle-emminger-pressekit.zip',
    meta: 'Optional · Logos im Pressekit',
    compact: true
  }
];

const photos = [
  {
    src: '/media/media-michelle-portrait-card.webp',
    href: '/media/media-michelle-portrait.webp',
    alt: 'Michelle Emminger im Coaching-Gespräch',
    title: 'Coaching & Gespräch',
    copy: 'Für Artikel, Interview-Ankündigungen und Kooperationsseiten.',
    width: 760,
    height: 507
  },
  {
    src: '/media/media-michelle-training-card.webp',
    href: '/media/media-michelle-training.webp',
    alt: 'Michelle Emminger begleitet eine Kundin beim Training',
    title: 'Personal Training',
    copy: 'Für Beiträge rund um 1:1 Training, Technik und persönliche Begleitung.',
    width: 760,
    height: 507
  },
  {
    src: '/media/media-michelle-coaching-card.webp',
    href: '/media/media-michelle-coaching.webp',
    alt: 'Michelle Emminger korrigiert eine Übung',
    title: '4-ME Method',
    copy: 'Für Methodik, Bewegungsausführung und alltagstaugliches Training.',
    width: 760,
    height: 507
  },
  {
    src: '/media/media-michelle-strength-card.webp',
    href: '/media/media-michelle-strength.webp',
    alt: 'Michelle Emminger zeigt Krafttraining',
    title: 'Kraft & Technik',
    copy: 'Für Themen zu Muskelaufbau, Functional Training und Gesundheitstraining.',
    width: 760,
    height: 507
  },
  {
    src: '/assets/about.webp',
    href: '/assets/about.webp',
    alt: 'Michelle Emminger Portrait',
    title: 'Portrait',
    copy: 'Für Personenportraits, Interviewprofile und Speaker-Vorstellungen.',
    width: 1200,
    height: 900
  },
  {
    src: '/assets/hero-training.webp',
    href: '/assets/hero-training.webp',
    alt: 'Michelle Emminger beim Training',
    title: 'Training Hero',
    copy: 'Für Aufmacher zu Personal Training, Kraftaufbau und Wiedereinstieg.',
    width: 1200,
    height: 900
  },
  {
    src: '/assets/personal-training.webp',
    href: '/assets/personal-training.webp',
    alt: 'Michelle Emminger im Personal Training',
    title: '1:1 Personal Training',
    copy: 'Für redaktionelle Beiträge zu Technik, Betreuung und Trainingsaufbau.',
    width: 1200,
    height: 900
  },
  {
    src: '/assets/contact.webp',
    href: '/assets/contact.webp',
    alt: 'Michelle Emminger Kontaktmotiv',
    title: 'Kontaktmotiv',
    copy: 'Für Kontaktboxen, Interviewankündigungen und redaktionelle Kurzprofile.',
    width: 1200,
    height: 900
  }
];

const topics = [
  'Personal Training in Wien für Menschen 40+',
  'From Struggle to Strength: Training mit eigener Transformationserfahrung',
  '4-ME Method: Körper, Vertrauen, Alltag und Fortschritt verbinden',
  'Rückenschmerzen, Haltung und Wiedereinstieg ins Training',
  'Office Fitness und kurze Bewegungseinheiten für Unternehmen',
  'Online Coaching, Hotelzimmer-Training und flexible Routinen auf Reisen',
  'Mentale Stärke, Selbstdisziplin und Stressregulierung im Trainingsprozess',
  'Warum Fitnesspläne angepasst werden müssen, statt jahrelang gleich zu bleiben'
];

const bios = [
  {
    label: 'Kurzbio · 50 Wörter',
    text: 'Michelle Emminger ist Personal-, Gesundheits- und Functional Trainerin in Wien. Mit ihrer 4-ME Method verbindet sie körperliches Training, mentale Stärke, Alltag und Fortschritt. Ihre eigene Transformation prägt ihren klaren, empathischen Ansatz: Training ohne Gym-Inszenierung, aber mit einem klaren Aufbau, Technik und persönlicher Begleitung.'
  },
  {
    label: 'Profil · 100 Wörter',
    text: 'Michelle Emminger begleitet Menschen in Wien und online als Personal-, Gesundheits- und Functional Trainerin. Ihre Arbeit basiert auf eigener Erfahrung: gesundheitliche Rückschläge, über 20 kg Gewichtszunahme, Rückenschmerzen, Selbstzweifel — und der Weg zurück zu Kraft, Körpergefühl und mentaler Stärke. Aus diesem Weg entstand ihre 4-ME Method: My Body, My Mind, My Life, My Success. Michelle begleitet Menschen, die wieder Kraft, Sicherheit und Vertrauen in ihren Körper aufbauen wollen und dafür eine ruhige, klare Begleitung suchen. Ihr Ansatz verbindet gute Technik, Rückmeldung, Vertrauen und Routinen, die in den Alltag passen.'
  }
];

const quotes = [
  'Ich begleite Menschen, die wieder Kraft, Sicherheit und Vertrauen in ihren Körper aufbauen wollen.',
  'Fortschritt passiert besser ohne Druck — aber mit einem klaren Plan, guter Technik und jemandem, der Rückschläge nicht nur aus der Theorie kennt.',
  'Ich will das ME in meinen Kunden wecken: das Bewusstsein, dass sie sich Zeit für sich selbst nehmen dürfen, wenn sie zu ihrem besten Ich werden wollen.'
];

const faq = [
  { q: 'Darf Bildmaterial direkt verwendet werden?', a: 'Das bereitgestellte Bildmaterial ist für redaktionelle Berichterstattung, Kooperationen und Ankündigungen gedacht. Bitte den konkreten Verwendungszweck prüfen und als Bildcredit Michelle Emminger angeben, sofern kein anderer Credit genannt wird.' },
  { q: 'Wer ist Ansprechpartnerin für Medien?', a: 'Für Medienanfragen ist Dr. Martina Zowack, Zowack PR & Communications, erreichbar: +43 676 3047112 oder martina.zowack@zowack.com.' },
  { q: 'Welche Themen eignen sich für Interviews?', a: 'Geeignet sind vor allem Michelles persönliche Transformation, die 4-ME Method, alltagstaugliches Training, Rückengesundheit, Office Fitness, mentale Stärke und Training für Menschen, die eine ruhige, klare Begleitung suchen.' },
  { q: 'Gibt es ein Buch von Michelle Emminger?', a: 'Ja. Michelle Emminger ist Autorin von „Das einfachste Trainingsbuch der Welt“. Das Buch verbindet ihre persönliche Abnehmreise mit einfachen Übungen, Ernährungsimpulsen und Motivation für den Einstieg.' }
];

const site = Astro.site || 'https://michelle.preview.convernatics.eu';
const mediaBase = new URL('/media-center/', site).toString();
const imageObjects = photos.map((photo) => ({
  '@type': 'ImageObject',
  name: `Michelle Emminger — ${photo.title}`,
  contentUrl: new URL(photo.href, site).toString(),
  thumbnailUrl: new URL(photo.src, site).toString(),
  caption: photo.copy,
  creditText: 'Michelle Emminger',
  creator: { '@type': 'Person', name: 'Michelle Emminger' },
  acquireLicensePage: mediaBase
}));
const extraSchema = [
  ...imageObjects,
  {
    '@type': 'Book',
    '@id': `${mediaBase}#trainingsbuch`,
    name: 'Das einfachste Trainingsbuch der Welt',
    author: { '@type': 'Person', name: 'Michelle Emminger' },
    image: new URL('/media/trainingsbuch-cover.webp', site).toString(),
    inLanguage: 'de-AT'
  },
  {
    '@type': 'ContactPoint',
    '@id': `${mediaBase}#medienkontakt`,
    contactType: 'media relations',
    name: 'Dr. Martina Zowack',
    email: mediaEmail,
    telephone: '+43 676 3047112',
    availableLanguage: ['de', 'en']
  }
];
---
<BaseLayout
  title="Pressefotos Michelle Emminger | Kurzprofil & Medienkontakt"
  description="Pressebereich von Michelle Emminger: Pressefotos, Kurzprofil, Factsheet, Presseinfo, O-Töne und Medienkontakt zur 4-ME Method."
  canonical="/media-center/"
  image="/media/media-michelle-portrait-hero.webp"
  pageType="CollectionPage"
  faq={faq}
  extraSchema={extraSchema}
  navCtaText="Medienanfrage senden"
  navCtaHref={mediaMailto}
  stickyCtaText="Medienanfrage senden"
  stickyCtaHref={mediaMailto}
  showStickyCta={false}
>
  <section class="service-hero media-hero">
    <div class="container split">
      <div>
        <p class="breadcrumbs"><a href="/">Start</a> / Media Center</p>
        <p class="eyebrow">Pressefotos · Kurzprofil · Medienkontakt</p>
        <h1 class="page-title">Pressebereich Michelle Emminger</h1>
        <p class="lead">Pressefotos, Kurzprofil, Factsheet, O-Töne und Medienkontakt für Artikel, Interviews, Bühnenformate und Kooperationen.</p>
        <div class="media-fact-strip" aria-label="Kurzüberblick">
          <span>Trainerin & Coach in Wien</span>
          <span>4-ME Method</span>
          <span>Autorin & Interviewgast</span>
        </div>
        <div class="hero-actions">
          <a class="btn primary" href="#bildmaterial">Pressebilder ansehen</a>
          <a class="btn light" href="/media/michelle-emminger-pressekit.zip" download>Pressekit herunterladen</a>
        </div>
      </div>
      <div class="image-card"><img src="/media/media-michelle-portrait-hero.webp" alt="Michelle Emminger im Gespräch mit einer Kundin" width="1280" height="853" loading="eager" decoding="async" fetchpriority="high" /></div>
    </div>
  </section>

  <section class="section media-kit-panel">
    <div class="container split media-intro">
      <div>
        <p class="eyebrow">Kurzprofil</p>
        <h2>Personal Coach und Fitness-Trainerin mit eigener Transformationserfahrung.</h2>
        <p class="answer-block">Michelle Emminger ist Personal-, Gesundheits- und Functional Trainerin in Wien. Ihre Arbeit verbindet fundiertes Fitness- und Gesundheitswissen mit einer selbst erlebten Transformation: gesundheitliche Rückschläge, über 20 kg Gewichtszunahme, Rückenschmerzen, Selbstzweifel — und der Weg zurück zu Kraft, Körpergefühl und mentaler Stärke.</p>
        <p>Aus dieser Erfahrung entstand ihre 4-ME Method: My Body, My Mind, My Life, My Success. Michelle begleitet Menschen, die wieder Kraft, Sicherheit und Vertrauen in ihren Körper aufbauen wollen. Ihr Ansatz ist persönlich, alltagstauglich und klar aufgebaut — ohne unrealistische Fitness- und Schönheitsideale.</p>
      </div>
      <div class="fact-card press-file-card">
        <h3>Factsheet</h3>
        <dl>
          {facts.map(([label, value]) => <><dt>{label}</dt><dd>{value}</dd></>)}
        </dl>
      </div>
    </div>
  </section>

  <section id="bildmaterial" class="section media-gallery-section">
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow">Pressebilder</p>
          <h2>Mehr Bildauswahl, schneller verwendbar.</h2>
        </div>
        <p>Ausgewählte Motive für Portrait, Training, Methode, Buch- und Interviewkontext. Für redaktionelle Nutzung bitte den Bildcredit <strong>Michelle Emminger</strong> nennen.</p>
      </div>
      <div class="usage-note">
        <strong>Nutzungshinweis:</strong> Frei für redaktionelle Berichterstattung, Interview-Ankündigungen und Kooperationskommunikation mit Credit. Bezahlte Werbung, starke Bearbeitung oder Sonderformate bitte vorab freigeben lassen.
      </div>
      <div class="media-photo-grid">
        {photos.map((photo) => (
          <a class="media-photo" href={photo.href} download>
            <img src={photo.src} alt={photo.alt} width={photo.width} height={photo.height} loading="eager" decoding="async" />
            <div>
              <h3>{photo.title}</h3>
              <p>{photo.copy}</p>
              <small>Bildcredit: Michelle Emminger</small>
              <span>Bild herunterladen</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section alt bio-section">
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow">Direkt verwendbar</p>
          <h2>Kurztexte für Ankündigungen und Redaktionen.</h2>
        </div>
        <p>Die Texte können als Einstieg für Artikel, Speaker-Vorstellungen, Eventseiten oder Kooperationsankündigungen verwendet werden.</p>
      </div>
      <div class="bio-grid">
        {bios.map((bio) => (
          <article class="copy-card">
            <span>{bio.label}</span>
            <p>{bio.text}</p>
            <button type="button" class="copy-button" data-copy={bio.text}>Text kopieren</button>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="downloads" class="section alt downloads-section">
    <div class="container">
      <p class="eyebrow">Downloads</p>
      <h2>Pressekit, Presseinfo und Kurzprofil.</h2>
      <p class="download-intro">Logos sind optional im Pressekit enthalten — der Fokus liegt hier bewusst auf direkt nutzbaren Bildern und redaktionellen Informationen.</p>
      <div class="download-grid">
        {downloads.map((item) => (
          <a class:list={["download-card", item.featured && "featured", item.compact && "compact"]} href={item.href} download>
            <span>{item.meta}</span>
            <h3>{item.title}</h3>
            <p>{item.copy}</p>
            <strong>Download</strong>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container split book-section">
      <div class="book-card">
        <img src="/media/trainingsbuch-cover-card.webp" alt="Cover Das einfachste Trainingsbuch der Welt von Michelle Emminger" width="760" height="530" loading="eager" decoding="async" />
      </div>
      <div>
        <p class="eyebrow">Buch & Hintergrund</p>
        <h2>„Das einfachste Trainingsbuch der Welt“</h2>
        <p>In ihrem Buch teilt Michelle Emminger ihre persönliche Abnehmreise und zeigt einfache, nachvollziehbare Wege zu einer Trainingsroutine, die wirklich begonnen werden kann. Es geht nicht um Perfektion, sondern um einen ersten machbaren Schritt zu mehr Kraft, Ausdauer und Wohlbefinden.</p>
        <p>Für Medien ist das Buch ein guter Einstieg in Michelles Grundhaltung: Fitness soll zugänglich sein, Mut machen und Menschen dabei unterstützen, dranzubleiben — auch wenn der eigene Ausgangspunkt schwierig ist.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split">
      <div>
        <p class="eyebrow">Themen für Interviews & Beiträge</p>
        <h2>Worüber Michelle sprechen kann.</h2>
        <p>Michelle eignet sich nicht nur für klassische Fitness-Beiträge. Ihre stärksten Themen liegen dort, wo Training, Alltag, Körpergefühl und mentale Stärke zusammenkommen.</p>
      </div>
      <div class="topic-list">
        {topics.map((topic) => <div>{topic}</div>)}
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container split">
      <div>
        <p class="eyebrow">Zitate</p>
        <h2>Direkt verwendbare O-Töne.</h2>
        <p>Die O-Töne können als Einstieg für Artikel, Interviewteaser oder Eventankündigungen verwendet werden.</p>
      </div>
      <div class="quote-stack">
        {quotes.map((quote) => (
          <blockquote>
            „{quote}”
            <button type="button" class="copy-button quote-copy" data-copy={`„${quote}”`}>Zitat kopieren</button>
          </blockquote>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split">
      <div>
        <p class="eyebrow">Medienkontakt</p>
        <h2>Für konkrete Anfragen.</h2>
        <p>Für Interviews, redaktionelle Beiträge, Presseinformationen und Kooperationsanfragen bitte direkt mit dem gewünschten Thema, Format und Zeitfenster melden.</p>
      </div>
      <div class="contact-card">
        <h3>Dr. Martina Zowack</h3>
        <p>Zowack PR & Communications</p>
        <p><a href="tel:+436763047112">+43 676 3047112</a><br /><a href={`mailto:${mediaEmail}`}>{mediaEmail}</a></p>
        <a class="btn primary" href={mediaMailto}>Medienanfrage senden</a>
      </div>
    </div>
  </section>

  <FAQ items={faq} heading="Antworten auf häufige Medienfragen" />

  <style>
    .media-gallery-section{background:#fff}
    .media-gallery-section .media-photo-grid{grid-template-columns:repeat(4,minmax(0,1fr))}
    .media-gallery-section .media-photo img{aspect-ratio:4/3}
    .downloads-section .download-intro{max-width:64ch;margin:-.4rem 0 1.2rem}
    .download-card.compact{background:#fff;box-shadow:none;border-style:dashed}
    @media(max-width:960px){.media-gallery-section .media-photo-grid{grid-template-columns:1fr 1fr}}
    @media(max-width:640px){.media-gallery-section .media-photo-grid{grid-template-columns:1fr}}
  </style>

  <script>
    document.querySelectorAll('[data-copy]').forEach((button) => {
      button.addEventListener('click', async () => {
        const value = button.getAttribute('data-copy') || '';
        try {
          await navigator.clipboard.writeText(value);
          const old = button.textContent;
          button.textContent = 'Kopiert';
          setTimeout(() => { button.textContent = old; }, 1600);
        } catch (error) {
          button.textContent = 'Kopieren nicht möglich';
        }
      });
    });
  </script>
</BaseLayout>
