import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Personal Training Wien | Michelle Emminger" description="1:1 Personal Training in Wien für Menschen 40+: Kraft, Haltung, Rücken, Routine und Körpergefühl mit Michelles 4-ME Method." canonical="/personal-training-wien/" image="/assets/personal-training.webp">
<section class="service-hero"><div class="container split"><div><p class="breadcrumbs"><a href="/">Start</a> / Personal Training Wien</p><p class="eyebrow">1:1 Personal Training Wien</p><h1 class="page-title">Persönliches Training, das dich fordert — ohne dich zu überfordern.</h1><p class="lead">Für Erwachsene 40+, die wieder stärker, beweglicher und sicherer werden wollen. Mit sauberer Technik, klarer Struktur und einem Plan, der in deinen Alltag passt.</p><div class="hero-actions"><a class="btn primary" href="#anfrage">Erstgespräch anfragen</a><a class="btn light" href="/rueckenschmerzen/">Rückenfokus ansehen</a></div></div><div class="image-card"><img src="/assets/personal-training.webp" alt="Personal Training mit Michelle Emminger in Wien" loading="eager"/></div></div></section>
<section class="section"><div class="container"><p class="eyebrow">Für wen?</p><h2>Wenn du nicht noch einen Plan brauchst, sondern Begleitung.</h2><div class="grid three"><div class="card"><h3>Nach Trainingspausen</h3><p>Du willst wieder starten, aber diesmal ohne Überforderung und Start-Stopp-Muster.</p></div><div class="card"><h3>Bei Rücken & Haltung</h3><p>Du möchtest Kraft, Mobilität und Core stabil aufbauen — mit sauberer Technik.</p></div><div class="card"><h3>Für mehr Energie</h3><p>Du willst dich im Alltag belastbarer fühlen und nicht nur „für die Waage“ trainieren.</p></div></div></div></section>
<section class="section alt"><div class="container split"><div><p class="eyebrow">Was du bekommst</p><h2>1:1 heißt: dein Körper, dein Kopf, dein Alltag.</h2><ul class="checklist"><li>Anamnese und realistisches Zielbild</li><li>Technik-Coaching und direkte Korrektur</li><li>Training für Kraft, Mobilität, Haltung und Belastbarkeit</li><li>Anpassung an Energielevel, Zeitfenster und Fortschritt</li><li>Optional online oder hybrid ergänzbar</li></ul></div><div class="card dark"><h3>Kein Einheitsbrei.</h3><p>Die 4-ME Method sorgt dafür, dass wir nicht nur Übungen abarbeiten. Wir bauen ein System, das zu deinem echten Leben passt.</p><a class="btn mint" href="/4-me-method/">4-ME Method lesen</a></div></div></section>

<section class="section alt" id="anfrage">
  <div class="container split">
    <div>
      <p class="eyebrow">Nächster Schritt</p>
      <h2>Kurz klären, ob es passt.</h2>
      <p class="lead">Schick Michelle kurz Ziel, Ausgangssituation und gewünschtes Format. In der Preview wird noch nichts produktiv versendet.</p>
      <ul class="checklist"><li>15–20 Minuten Kennenlernen</li><li>Training, Online Coaching oder B2B-Pilot einordnen</li><li>Keine Verpflichtung, kein Druck</li></ul>
    </div>
    <form class="card form" name="preview-anfrage" action="/danke/" method="get">
      <input name="name" placeholder="Name" required />
      <input name="kontakt" placeholder="E-Mail oder Telefon" required />
      <select name="format"><option>1:1 Personal Training</option><option>Online Coaching</option><option>Firmenfitness / Office Fitness</option><option>Noch unsicher</option></select>
      <textarea name="nachricht" rows="4" placeholder="Ziel, größte Hürde, Ort/Bezirk oder Teamgröße"></textarea>
      <button class="btn primary" type="submit">Anfrage vormerken</button>
      <p class="seo-note">Preview-Formular. Für Produktion später echte Zieladresse/Terminbuchung ergänzen.</p>
    </form>
  </div>
</section>
</BaseLayout>
