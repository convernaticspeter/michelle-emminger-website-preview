---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQ from '../components/FAQ.astro';
import Inquiry from '../components/Inquiry.astro';
const faq = [
  { q: 'Was ist Firmenfitness mit Michelle Emminger?', a: 'Firmenfitness mit Michelle Emminger sind kurze, professionell angeleitete Bewegungseinheiten für Teams in Wien. Der Fokus liegt auf Rücken, Nacken, Mobilität, Energie und alltagstauglicher Bewegung direkt im Büro oder Meetingraum.' },
  { q: 'Brauchen Mitarbeitende Sportkleidung?', a: 'Nein. Das Format ist bewusst niedrigschwellig. Viele Einheiten funktionieren im Büro, ohne Umziehen und ohne Gerätepflicht. Dadurch sinkt die Hürde für Mitarbeitende, die sich von klassischen Fitnessangeboten nicht angesprochen fühlen.' },
  { q: 'Für welche Unternehmen eignet sich Office Fitness?', a: 'Office Fitness eignet sich für Teams, die viel sitzen, konzentriert arbeiten und einfache Bewegung in den Arbeitsalltag bringen wollen. Besonders passend ist es für Büros, Agenturen, Kanzleien, Praxen und Unternehmen, die erst klein testen möchten.' },
  { q: 'Wie startet man am besten?', a: 'Der beste Einstieg ist meistens eine Testsession oder ein kurzer Pilot. So sieht das Team, wie das Format ankommt, welche Themen relevant sind und ob ein regelmäßiger Slot Sinn macht.' },
  { q: 'Verspricht Firmenfitness weniger Krankenstand?', a: 'Michelle arbeitet nicht mit erfundenen ROI-Versprechen. Gut messbar sind Teilnahme, Feedback, Stimmung, Akzeptanz und die Frage, ob Mitarbeitende Bewegung tatsächlich leichter in den Arbeitstag bekommen.' }
];
---
<BaseLayout title="Firmenfitness Wien | Office Fitness mit Michelle Emminger" description="Firmenfitness in Wien: kurze Office-Fitness-Einheiten für Rücken, Nacken, Mobilität und Energie — als Testsession oder Pilot für Teams." canonical="/firmenfitness/" image="/assets/firmenfitness-office-squats.webp" faq={faq} serviceName="Firmenfitness Wien und Office Fitness">
<section class="service-hero"><div class="container split"><div><p class="breadcrumbs"><a href="/">Start</a> / Firmenfitness Wien</p><p class="eyebrow">Office Fitness für Teams</p><h1 class="page-title">Firmenfitness in Wien</h1><p class="lead">Kurze Bewegungseinheiten für Teams – direkt im Unternehmen, ohne Umziehen, ohne Show und mit einem Format, das sich gut testen lässt.</p><div class="hero-actions"><a class="btn primary" href="#anfrage">Pilot anfragen</a><a class="btn light" href="/4-me-method/">Methode ansehen</a></div></div><div class="image-card"><img src="/assets/firmenfitness-office-squats.webp" alt="Michelle Emminger leitet eine Office-Fitness-Einheit mit Kniebeugen im Besprechungsraum" loading="eager" fetchpriority="high"/></div></div></section>
<section class="section"><div class="container narrow"><p class="eyebrow">Direkte Antwort</p><h2>Was ist Office Fitness mit Michelle Emminger?</h2><p class="answer-block">Office Fitness mit Michelle Emminger ist Firmenfitness für Unternehmen in Wien, die Bewegung niedrigschwellig in den Büroalltag bringen wollen. Die Einheiten dauern kurz, brauchen wenig Vorbereitung und konzentrieren sich auf Rücken, Nacken, Mobilität, Energie und kleine Routinen, die Mitarbeitende wirklich mitnehmen.</p><p>Viele Firmenfitness-Angebote scheitern nicht am guten Willen, sondern an der Hürde: zu sportlich, zu groß, zu viel Organisation — und dann interessiert sich doch niemand. Michelle dreht das um. Erst wird klein getestet, dann wird gemeinsam entschieden, was wirklich zum Team passt.</p></div></section>
<section class="section alt"><div class="container"><p class="eyebrow">Für HR, Office Management & Geschäftsführung</p><h2>Erst klein testen. Dann in Ruhe ausbauen.</h2><div class="grid three"><div class="card"><div class="num">A</div><h3>Testsession</h3><p>20–45 Minuten zu Rücken, Nacken, Mobilität oder Energie-Reset. Ideal, um Akzeptanz im Team zu prüfen, ohne gleich ein großes Programm aufzusetzen.</p></div><div class="card"><div class="num">B</div><h3>4-Wochen-Pilot</h3><p>Fixer Slot, klarer Schwerpunkt und kurzes Feedback danach. So wird sichtbar, ob Teilnahme, Stimmung und Praktikabilität passen.</p></div><div class="card"><div class="num">C</div><h3>Regelmäßiges Format</h3><p>Nach positivem Pilot kann daraus ein wiederkehrendes Format entstehen: mit Schwerpunktplanung, einfacher Kommunikation und stabiler Routine.</p></div></div></div></section>
<section class="section"><div class="container split"><div><p class="eyebrow">Warum es funktioniert</p><h2>Keine Show, kein großer Aufwand – einfach eine kurze Bewegungseinheit, die gut in den Arbeitstag passt.</h2><p>Ein Team braucht nicht immer ein großes Sportprogramm. Oft reicht ein Format, das Hemmschwellen senkt und den Körper aus dem Sitzmodus holt. Genau deshalb arbeitet Michelle mit klaren, einfachen Einheiten, die sich in den Arbeitstag einfügen.</p><ul class="checklist"><li>Direkt im Büro oder Meetingraum</li><li>Keine Sportkleidung zwingend notwendig</li><li>Fokus auf Rücken, Nacken, Mobilität und Energie</li><li>Niedrige Hürde auch für unsportliche Mitarbeitende</li><li>Kommunikation, die nicht nach Pflichtprogramm klingt</li></ul></div><div class="card dark"><h3>4-ME Method für Teams</h3><p>My Body, My Mind, My Life und My Success werden fürs Unternehmen übersetzt: Körper entlasten, Kopf freier bekommen, Arbeitsalltag berücksichtigen und kleine Erfolge sichtbar machen.</p><a class="btn mint" href="/4-me-method/">4-ME Method lesen</a></div></div></section>
<section class="section alt"><div class="container split"><div class="image-card"><img src="/assets/firmenfitness-theraband-row.webp" alt="Office Fitness mit Therabändern: Michelle Emminger korrigiert Rudern im Stehen" loading="lazy"/></div><div><p class="eyebrow">Typische Themen</p><h2>Langes Sitzen, Stress und wenig Bewegung zeigen sich oft zuerst im Nacken.</h2><p>Viele Teams kennen dieselben Muster: lange Meetings, kein Raumwechsel, verspannte Schultern schon vor dem Mittagessen, kurze Pausen die doch wieder am Bildschirm enden, und am Nachmittag ein kollektives Energieminus. Michelle macht daraus kein Drama — sondern einen machbaren Startpunkt.</p><div class="grid two"><div class="mini-card"><h3>Rücken & Nacken</h3><p>Kurze Mobilitäts- und Aktivierungseinheiten gegen typische Sitzbelastung.</p></div><div class="mini-card"><h3>Energie & Fokus</h3><p>Bewegung, die den Arbeitstag unterbricht, ohne den Arbeitsfluss zu zerstören.</p></div><div class="mini-card"><h3>Teamgefühl</h3><p>Gemeinsam bewegen, ohne Wettbewerb, Blamage oder Fitnessdruck.</p></div><div class="mini-card"><h3>Akzeptanz</h3><p>Ein Format, das auch Menschen erreicht, die beim Wort Fitness sonst innerlich aussteigen.</p></div></div></div></div></section>
<section class="section"><div class="container narrow"><p class="eyebrow">Entscheidungslogik</p><h2>Gute Firmenfitness beginnt nicht mit einem Jahresprogramm.</h2><p>Für Unternehmen ist der beste nächste Schritt meistens klein: eine Testsession, ein klarer Schwerpunkt, ein kurzer Feedbackbogen und eine ehrliche Auswertung. Wenn die Akzeptanz da ist, lässt sich das Format ausbauen. Wenn nicht, wurde nichts aufgebläht und keine große Erwartung enttäuscht.</p><p>Michelles Ansatz ist derselbe wie im 1:1 Training: Veränderung passiert besser ohne Druck, aber mit dem richtigen Rahmen. Was für Teams funktioniert, ist ein Format das Menschen tatsächlich annehmen — nicht eines, das sie tolerieren.</p></div></section>
<FAQ items={faq} heading="Häufige Fragen zu Firmenfitness" />
<Inquiry format="Firmenfitness / Office Fitness" heading="Schick kurz Teamgröße, Standort und gewünschte Schwerpunkte." copy="Für den Einstieg reichen Teamgröße, Ort in Wien oder Umgebung, gewünschter Schwerpunkt und ein grobes Zeitfenster. Daraus lässt sich einschätzen, ob Testsession oder Pilot besser passt." />
</BaseLayout>
