---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQ from '../components/FAQ.astro';
import Inquiry from '../components/Inquiry.astro';
const faq = [
  { q: 'Hilft Personal Training bei Rückenschmerzen?', a: 'Personal Training kann bei vielen Rücken- und Haltungsthemen gut unterstützen, wenn Belastung, Technik und Beweglichkeit gezielt aufgebaut werden. Es ersetzt keine medizinische Abklärung, hilft aber dabei, wieder Vertrauen in Bewegung zu entwickeln.' },
  { q: 'Wann sollte ich Rückenschmerzen ärztlich abklären?', a: 'Wenn Schmerzen stark, neu, ausstrahlend, mit Taubheit verbunden oder nach Unfall entstanden sind, sollte medizinisch abgeklärt werden. Training beginnt dann erst im passenden Rahmen und nicht gegen Warnsignale des Körpers.' },
  { q: 'Was macht Michelle bei Rückenfokus anders?', a: 'Michelle arbeitet nicht mit blindem Durchbeißen. Zuerst wird verstanden, welche Bewegungen unsicher sind, wie dein Alltag aussieht und welche Belastung gut machbar ist. Danach werden Core, Mobilität, Haltung und Kraft Schritt für Schritt aufgebaut.' },
  { q: 'Ist Rückentraining nur Dehnen?', a: 'Nein. Gutes Rückentraining verbindet Beweglichkeit, Kraft, Kontrolle, Atmung, Haltung und Belastbarkeit. Dehnen kann Teil davon sein, ersetzt aber keinen strukturierten Aufbau.' }
];
---
<BaseLayout title="Personal Training bei Rückenschmerzen Wien | Michelle Emminger" description="Personal Training bei Rückenschmerzen in Wien: Rücken, Core, Haltung und Beweglichkeit gezielt aufbauen — mit Michelle Emmingers 4-ME Method." canonical="/rueckenschmerzen/" image="/assets/back.webp" faq={faq} serviceName="Personal Training bei Rückenschmerzen Wien">
<section class="service-hero"><div class="container split"><div><p class="breadcrumbs"><a href="/">Start</a> / Rückenschmerzen</p><p class="eyebrow">Rücken · Core · Haltung</p><h1 class="page-title">Personal Training bei Rückenschmerzen in Wien</h1><p class="lead">Für Menschen mit Rückenschmerzen, die ihrem Rücken wieder mehr zutrauen wollen – Schritt für Schritt, mit Kraft, Kontrolle und einem gut machbaren Aufbau.</p><div class="hero-actions"><a class="btn primary" href="#anfrage">Rückenfokus anfragen</a><a class="btn light" href="/personal-training-wien/">Personal Training</a></div></div><div class="image-card"><img src="/assets/back.webp" alt="Rückentraining mit Michelle Emminger in Wien" loading="eager" fetchpriority="high"/></div></div></section>
<section class="section"><div class="container narrow"><p class="eyebrow">Direkte Antwort</p><h2>Wie kann Personal Training bei Rückenschmerzen helfen?</h2><p class="answer-block">Personal Training bei Rückenschmerzen hilft, Bewegung wieder kontrollierter, kräftiger und sicherer aufzubauen. Michelle Emminger verbindet Core-Training, Mobilität, Haltung, Technik und Alltag, damit der Rücken nicht nur geschont wird, sondern wieder mehr Vertrauen bekommt.</p><p>Viele Rückenthemen werden im Alltag größer: Stunden am Bildschirm, wenig echte Bewegung, Stress, unsichere Muskulatur, Angst vor Belastung. Das betrifft besonders Menschen, deren Arbeitstag zu 80 Prozent im Sitzen stattfindet. Michelle startet deshalb nicht mit maximaler Intensität, sondern mit Einordnung, Technik und einem Aufbau, der Vertrauen schafft — und der im echten Alltag auch umsetzbar ist.</p></div></section>
<section class="section alt"><div class="container split"><div><p class="eyebrow">Typische Ausgangslage</p><h2>Wenn du dich bewegst, aber deinem Rücken nicht mehr ganz traust.</h2><p>Das Ziel ist nicht, Schmerzen schönzureden. Das Ziel ist, ruhig zu unterscheiden: Was braucht medizinische Abklärung? Was braucht bessere Bewegung? Was braucht Kraft? Und wo macht der Alltag den Rücken immer wieder müde — lange Bildschirmtage, wenig Bewegung, Stress?</p><ul class="checklist"><li>Rücken fühlt sich instabil oder schnell überlastet an</li><li>stundenlang sitzen sitzt dir abends im Nacken oder unteren Rücken</li><li>du vermeidest bestimmte Bewegungen aus Unsicherheit oder alter Gewohnheit</li><li>du willst wieder aktiver werden, aber weißt nicht, was deinem Rücken wirklich hilft</li><li>du bist 40+ und merkst, dass der Körper nach dem Büroalltag länger braucht, um sich zu erholen</li></ul></div><div class="card dark"><h3>Wichtig</h3><p>Training ersetzt keine Diagnose. Wenn Warnsignale da sind, gehört das medizinisch geklärt. Danach kann Training helfen, wieder strukturiert aufzubauen.</p></div></div></section>
<section class="section"><div class="container"><p class="eyebrow">Aufbau</p><h2>Rückenstärke entsteht nicht durch eine einzelne Wunderübung.</h2><div class="grid four"><div class="card"><h3>Core</h3><p>Stabilität und Kontrolle aufbauen, damit Bewegungen sicherer werden.</p></div><div class="card"><h3>Mobilität</h3><p>Bewegungsräume zurückholen, ohne in Schmerz oder Unsicherheit zu trainieren.</p></div><div class="card"><h3>Technik</h3><p>Alltags- und Trainingsbewegungen sicherer und besser ausführen lernen.</p></div><div class="card"><h3>Belastbarkeit</h3><p>Schrittweise stärker werden, statt ewig im Schonmodus zu bleiben.</p></div></div></div></section>
<FAQ items={faq} heading="Häufige Fragen zu Rückenschmerzen und Training" />
<Inquiry format="1:1 Personal Training" heading="Beschreib kurz deine Beschwerden und wie sie sich im Alltag zeigen." copy="Für eine erste Einschätzung helfen: Wo spürst du Beschwerden, wann treten sie auf, was wurde bereits abgeklärt und welches Ziel hättest du gern wieder im Alltag oder Training?" />
</BaseLayout>
