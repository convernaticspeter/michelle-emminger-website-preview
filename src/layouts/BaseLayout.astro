---
import '../styles/global.css';
const {
  title = 'Michelle Emminger | Personal Training Wien',
  description = 'Personal Training, Online Coaching und Office Fitness in Wien mit Michelle Emminger.',
  canonical = '/',
  image = '/assets/link-preview-michelle.jpg',
  pageType = 'WebPage',
  faq = [],
  serviceName = '',
  extraSchema = [],
  navCtaText = 'Einschätzung anfragen',
  navCtaHref = '/kontakt/',
  stickyCtaText = navCtaText,
  stickyCtaHref = navCtaHref,
  showStickyCta = true
} = Astro.props;
const site = Astro.site || 'https://michelle.preview.convernatics.eu';
const url = new URL(canonical, site).toString();
const imageUrl = new URL(image, site).toString();
const orgId = `${site}#organization`;
const personId = `${site}#michelle-emminger`;
const websiteId = `${site}#website`;
const pageId = `${url}#webpage`;
const graph = [
  {
    '@type': ['Organization', 'LocalBusiness'],
    '@id': orgId,
    name: 'Michelle Emminger Personal Training',
    alternateName: ['Michelle Emminger', '4-ME Method', 'Become your best ME'],
    url: site.toString(),
    logo: new URL('/assets/logo.png', site).toString(),
    image: imageUrl,
    areaServed: [{ '@type': 'City', name: 'Wien' }, { '@type': 'Country', name: 'Österreich' }, 'Online'],
    description: 'Personal Training, Online Coaching und Firmenfitness in Wien nach der 4-ME Method: My Body, My Mind, My Life und My Success.',
    founder: { '@id': personId },
    makesOffer: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Personal Training Wien' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Online Coaching' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Firmenfitness Wien und Office Fitness' } }
    ]
  },
  {
    '@type': 'Person',
    '@id': personId,
    name: 'Michelle Emminger',
    jobTitle: 'Personal-, Gesundheits- und Functional Trainerin',
    description: 'Michelle Emminger begleitet Menschen in Wien und online von Rückschlägen mit Körper, Energie und Routine hin zu mehr Kraft, Haltung und Selbstvertrauen. Ihre Arbeit basiert auf ihrer eigenen Transformation und der 4-ME Method.',
    image: new URL('/assets/about.webp', site).toString(),
    worksFor: { '@id': orgId },
    knowsAbout: ['Personal Training', 'Functional Training', 'Gesundheitstraining', 'Rückentraining', 'Muskelaufbau', 'Firmenfitness', 'Office Fitness', 'Online Coaching', '4-ME Method']
  },
  {
    '@type': 'WebSite',
    '@id': websiteId,
    name: 'Michelle Emminger Personal Training',
    url: site.toString(),
    inLanguage: 'de-AT',
    publisher: { '@id': orgId }
  },
  {
    '@type': pageType,
    '@id': pageId,
    url,
    name: title,
    description,
    image: imageUrl,
    isPartOf: { '@id': websiteId },
    about: serviceName ? { '@type': 'Service', name: serviceName, provider: { '@id': orgId }, areaServed: 'Wien' } : { '@id': personId },
    primaryImageOfPage: { '@type': 'ImageObject', url: imageUrl },
    inLanguage: 'de-AT'
  },
  {
    '@type': 'BreadcrumbList',
    '@id': `${url}#breadcrumb`,
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Startseite', item: site.toString() },
      ...(canonical !== '/' ? [{ '@type': 'ListItem', position: 2, name: title.split('|')[0].trim(), item: url }] : [])
    ]
  }
];
if (serviceName) {
  graph.push({
    '@type': 'Service',
    '@id': `${url}#service`,
    name: serviceName,
    provider: { '@id': orgId },
    areaServed: ['Wien', 'Online'],
    serviceType: serviceName,
    description
  });
}
if (faq.length) {
  graph.push({
    '@type': 'FAQPage',
    '@id': `${url}#faq`,
    mainEntity: faq.map((item) => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: { '@type': 'Answer', text: item.a }
    }))
  });
}
const schema = { '@context': 'https://schema.org', '@graph': [...graph, ...extraSchema] };
---
<html lang="de-AT">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={url} />
  <meta name="robots" content={import.meta.env.PUBLIC_ROBOTS || 'noindex,follow'} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={url} />
  <meta property="og:image" content={imageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="Michelle Emminger begleitet Personal Training in Wien" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content={imageUrl} />
  <link rel="icon" href="/assets/favicon.png" />
  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
</head>
<body>
  <header class="site-header">
    <div class="container nav">
      <a href="/" aria-label="Michelle Emminger Startseite"><img class="logo" src="/assets/logo.png" alt="Michelle Emminger Logo" width="1024" height="1024" /></a>
      <nav class="menu desktop-menu" aria-label="Hauptnavigation">
        <a href="/leistungen/">Leistungen</a>
        <details class="nav-group">
          <summary>Training</summary>
          <div class="nav-panel">
            <a href="/personal-training-wien/"><strong>Personal Training</strong><span>1:1 in Wien</span></a>
            <a href="/rueckenschmerzen/"><strong>Rückentraining</strong><span>Core, Haltung, Belastbarkeit</span></a>
            <a href="/muskelaufbau/"><strong>Muskelaufbau</strong><span>Kraft gezielt aufbauen</span></a>
            <a href="/online-coaching/"><strong>Online Coaching</strong><span>flexibel begleitet</span></a>
            <a href="/firmenfitness/"><strong>Firmenfitness</strong><span>Office Fitness für Teams</span></a>
          </div>
        </details>
        <a href="/4-me-method/">4-ME Method</a>
        <a href="/ueber-mich/">Über Michelle</a>
        <a href="/media-center/">Media</a>
        <a class="nav-cta" href={navCtaHref}>{navCtaText}</a>
      </nav>
      <details class="mobile-menu">
        <summary aria-label="Menü öffnen">Menü</summary>
        <nav aria-label="Mobile Hauptnavigation">
          <a href="/leistungen/">Leistungen Übersicht</a>
          <a href="/personal-training-wien/">Personal Training Wien</a>
          <a href="/rueckenschmerzen/">Rückentraining Wien</a>
          <a href="/muskelaufbau/">Muskelaufbau</a>
          <a href="/online-coaching/">Online Coaching</a>
          <a href="/firmenfitness/">Firmenfitness</a>
          <a href="/4-me-method/">4-ME Method</a>
          <a href="/ueber-mich/">Über Michelle</a>
          <a href="/media-center/">Media Center</a>
          <a class="nav-cta" href={navCtaHref}>{navCtaText}</a>
        </nav>
      </details>
    </div>
  </header>
  <main><slot /></main>
  {showStickyCta && <a class="sticky-cta" href={stickyCtaHref}>{stickyCtaText}</a>}
  <footer class="footer">
    <div class="container footer-grid">
      <div><img class="logo" src="/assets/logo-white.png" alt="Michelle Emminger Logo weiß" width="1024" height="1024" /><p>From Struggle to Strength: Personal Training, Online Coaching und Office Fitness in Wien. Klar, persönlich und alltagstauglich.</p></div>
      <div><strong>Leistungen</strong><p><a href="/personal-training-wien/">Personal Training Wien</a><br/><a href="/rueckenschmerzen/">Rückentraining Wien</a><br/><a href="/muskelaufbau/">Muskelaufbau Personal Training</a><br/><a href="/online-coaching/">Online Coaching</a><br/><a href="/firmenfitness/">Firmenfitness Wien</a></p></div>
      <div><strong>Michelle</strong><p><a href="/4-me-method/">4-ME Method</a><br/><a href="/ueber-mich/">Über Michelle</a><br/><a href="/leistungen/">Leistungen</a><br/><a href="/kontakt/">Kontakt</a><br/><a href="/media-center/">Media Center</a></p></div>
      <div><strong>Rechtliches</strong><p><a href="/impressum/">Impressum</a><br/><a href="/datenschutz/">Datenschutz</a></p></div>
    </div>
  </footer>
</body>
</html>
